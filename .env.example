# Local dev: copy to `.env` and fill real values (NEVER commit `.env`).
# Production: set these as GitHub Secrets (sensitive) and Variables (non-sensitive).
# The deploy workflow injects them into the containers; no .env file on the host.

# --- App ---
# Project name: Docker image names, Traefik router, and the deploy dir derive from it.
PROJECT_NAME=fullstack-webapp-template

# --- Database (PostgreSQL) ---
# POSTGRES_USER and POSTGRES_DB are derived from PROJECT_NAME (dev: compose, prod: workflow).
# Only the password is set here / as a secret. Percent-encode reserved characters
# when placing the local password in DATABASE_URL (the deploy workflow does this automatically).
POSTGRES_PASSWORD=change-me
# Prisma connection string for local dev (the Dockerized DB is published on localhost).
# User and DB name must match PROJECT_NAME (compose derives POSTGRES_USER/POSTGRES_DB from it).
DATABASE_URL=postgresql://fullstack-webapp-template:change-me@localhost:5432/fullstack-webapp-template?schema=public

# --- Auth.js / NextAuth ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=
# Canonical external origin. Production derives this from APP_DOMAIN.
NEXTAUTH_URL=http://localhost:3000
# Accept forwarding headers only when direct access to the app is blocked.
# Enable only when Cloudflare is the exclusive origin path and the ingress
# overwrites forwarded host and cf-connecting-ip headers on every request.
TRUST_PROXY_HEADERS=false

# --- SMTP (Nodemailer) — external transactional provider, required for email sign-in ---
# Deliberate feature gate. Keep false until the first product spec implements
# existing-user-only authentication and its tests. SMTP values alone do not enable auth.
AUTH_EMAIL_ENABLED=false
# Point these at a transactional email provider (SendGrid, Postmark, Mailgun,
# Amazon SES, Brevo, Resend, ...), NOT a self-hosted mail server.
# In production set SMTP_HOST/PORT/SECURE/FROM as GitHub Variables and
# SMTP_USER/SMTP_PASSWORD as GitHub Secrets.
SMTP_HOST=
SMTP_PORT=
# true = implicit TLS (port 465); false = STARTTLS (587/25). Defaults to true only on 465.
SMTP_SECURE=
SMTP_USER=
SMTP_PASSWORD=
# Must be an address your provider is authorized to send from (verified domain).
SMTP_FROM=

# --- Logging (optional) ---
# fatal | error | warn | info | debug | trace | silent
LOG_LEVEL=
